generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  
}

enum ProductType {
  COUPON
}

enum ValueType {
  STRING
  IMAGE
}

model Product {
  id          String   @id @default(uuid())
  name        String
  description String
  type        ProductType
  imageUrl    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  coupon      Coupon?

  @@map("products")
}

model Coupon {
  id                 String   @id @default(uuid())
  productId          String   @unique
  costPrice          Decimal
  marginPercentage   Decimal
  minimumSellPrice   Decimal
  isSold             Boolean  @default(false)

  valueType          ValueType
  value              String

  product            Product  @relation(fields: [productId], references: [id])

  @@map("coupons")
}