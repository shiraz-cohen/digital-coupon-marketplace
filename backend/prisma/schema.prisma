generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  
}

enum ProductType {
  COUPON
}

enum ValueType {
  STRING
  IMAGE
}

enum UserRole {
  ADMIN
  CUSTOMER
  RESELLER
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String? 
  role      UserRole
  apiToken  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  purchases Purchase[]
}

model Product {
  id          String   @id @default(uuid())
  name        String
  description String
  type        ProductType
  imageUrl    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  coupon      Coupon?
  purchases   Purchase[]

  @@map("products")
}

model Coupon {
  id                 String   @id @default(uuid())
  productId          String   @unique
  costPrice          Decimal
  marginPercentage   Decimal
  minimumSellPrice   Decimal
  isSold             Boolean  @default(false)

  valueType          ValueType
  value              String

  product            Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("coupons")
}

model Purchase {
  id        String    @id @default(uuid())
  userId    String
  productId String
  pricePaid Decimal
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id])
  product   Product   @relation(fields: [productId], references: [id])

  @@map("purchases")
}